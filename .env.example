# Bot Token dari @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Admin IDs (comma-separated). Kosongkan untuk allow semua user.
ADMIN_IDS=123456789,987654321

# Delay antar CC check dalam detik
DELAY_BETWEEN=3

# Proxy (opsional, bisa diset via /setproxy juga)
# Format: http://ip:port atau socks5://user:pass@ip:port
# Bisa comma-separated untuk multiple proxy
PROXY_URL=http://127.0.0.1:8080
